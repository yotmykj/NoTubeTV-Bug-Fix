(function () {
    if (window.__sponsorblock_initialized) return;
    window.__sponsorblock_initialized = true;

    let currentVideoId = null;
    let segments = [];

    // Получение ID текущего видео из URL или интерфейса TV
    function getVideoId() {
        const match = window.location.href.match(/v=([a-zA-Z0-9_-]{11})/);
        if (match) return match[1];
        
        // Резервный вариант для YouTube TV
        const video = document.querySelector('video');
        if (video && video.src) {
            const srcMatch = video.src.match(/v=([a-zA-Z0-9_-]{11})/);
            if (srcMatch) return srcMatch[1];
        }
        return null;
    }

    // Запрос сегментов с сервера SponsorBlock
    function fetchSegments(videoId) {
        const categories = '["sponsor","intro","outro","interaction","selfpromo"]';
        const url = `https://sponsor.ajay.app/api/skipSegments?videoID=${videoId}&categories=${encodeURIComponent(categories)}`;

        // Если доступен нативный NetworkBridge (из твоего проекта)
        if (window.NetworkBridge && window.NetworkBridge.fetch) {
            window.NetworkBridge.fetch(url, 'GET', '', function(response) {
                try {
                    segments = JSON.parse(response);
                } catch (e) {
                    segments = [];
                }
            });
        } else {
            // Обычный fetch на случай прямых запросов
            fetch(url)
                .then(res => res.json())
                .then(data => { segments = data; })
                .catch(() => { segments = []; });
        }
    }

    // Проверка времени и автопропуск интеграций
    function checkAndSkip() {
        const video = document.querySelector('video');
        if (!video || video.paused) return;

        const videoId = getVideoId();
        if (videoId && videoId !== currentVideoId) {
            currentVideoId = videoId;
            segments = [];
            fetchSegments(videoId);
        }

        if (!segments || segments.length === 0) return;

        const currentTime = video.currentTime;

        for (const item of segments) {
            if (item.segment && item.segment.length === 2) {
                const start = item.segment[0];
                const end = item.segment[1];

                // Если попали на спонсорский отрезок — мгновенно перематываем на конец
                if (currentTime >= start && currentTime < end - 0.5) {
                    video.currentTime = end;
                    showToast('Пропущена интеграция (SponsorBlock)');
                    break;
                }
            }
        }
    }

    // Небольшое уведомление на экране TV
    function showToast(text) {
        let toast = document.getElementById('sb-toast');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'sb-toast';
            toast.style.cssText = `
                position: fixed;
                bottom: 50px;
                right: 50px;
                background: rgba(0, 0, 0, 0.85);
                color: #fff;
                padding: 12px 24px;
                border-radius: 8px;
                font-size: 18px;
                z-index: 99999;
                transition: opacity 0.3s ease;
            `;
            document.body.appendChild(toast);
        }
        toast.innerText = text;
        toast.style.opacity = '1';
        setTimeout(() => { toast.style.opacity = '0'; }, 2500);
    }

    // Проверяем плеер каждые 500 мс
    setInterval(checkAndSkip, 500);
})();
