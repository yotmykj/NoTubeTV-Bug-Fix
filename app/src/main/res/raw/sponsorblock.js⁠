(function () {
    if (window.__tizentube_initialized) return;
    window.__tizentube_initialized = true;

    // Настройки по умолчанию
    window.SB_SETTINGS = {
        enabled: true,
        skipSponsor: true,
        skipIntro: true,
        skipOutro: true,
        skipInteraction: true,
        skipSelfpromo: true,
        showToast: true
    };

    // 1. Надежное приветствие при старте (с максимальным z-index)
    function showWelcomeToast() {
        if (document.getElementById('tizen-welcome-toast')) return;
        
        const welcome = document.createElement('div');
        welcome.id = 'tizen-welcome-toast';
        welcome.style.cssText = `
            position: fixed;
            top: 40px;
            right: 40px;
            background: rgba(18, 18, 18, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-left: 6px solid #FF0000;
            color: #FFFFFF;
            padding: 16px 24px;
            border-radius: 12px;
            font-family: Roboto, sans-serif;
            font-size: 18px;
            z-index: 2147483647;
            box-shadow: 0 10px 30px rgba(0,0,0,0.9);
            transition: opacity 0.5s ease;
        `;
        welcome.innerHTML = `
            <div style="font-weight: bold; margin-bottom: 4px; color: #FF0000;">NoTube TV (TizenTube)</div>
            <div style="font-size: 15px; color: #CCCCCC;">SponsorBlock и блокировщик активны ✅</div>
        `;
        
        const targetContainer = document.body || document.documentElement;
        targetContainer.appendChild(welcome);

        setTimeout(() => {
            welcome.style.opacity = '0';
            setTimeout(() => welcome.remove(), 500);
        }, 4000);
    }

    // Запускаем показ приветствия через 2.5 секунды после старта
    setTimeout(showWelcomeToast, 2500);

    // 2. Окно настроек TizenTube
    function createTizenSettingsDialog() {
        if (document.getElementById('tizen-settings-overlay')) return;

        const overlay = document.createElement('div');
        overlay.id = 'tizen-settings-overlay';
        overlay.style.cssText = `
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0, 0, 0, 0.85);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2147483647;
            font-family: Roboto, sans-serif;
        `;

        overlay.innerHTML = `
            <div style="background: #1e1e1e; border: 1px solid rgba(255,255,255,0.15); width: 550px; padding: 30px; border-radius: 16px; color: #fff; box-shadow: 0 25px 60px rgba(0,0,0,0.9);">
                <h2 style="margin-top: 0; font-size: 24px; color: #FF0000; display: flex; align-items: center; gap: 10px;">
                    ⚙️ Настройки TizenTube / SponsorBlock
                </h2>
                <div style="margin: 20px 0; display: flex; flex-direction: column; gap: 14px;">
                    <label style="display: flex; justify-content: space-between; align-items: center; font-size: 17px; cursor: pointer; background: rgba(255,255,255,0.05); padding: 10px 14px; border-radius: 8px;">
                        <span>Включить SponsorBlock</span>
                        <input type="checkbox" id="tizen-sb-enabled" ${window.SB_SETTINGS.enabled ? 'checked' : ''} style="width: 22px; height: 22px; accent-color: #FF0000;">
                    </label>
                    <label style="display: flex; justify-content: space-between; align-items: center; font-size: 17px; cursor: pointer; background: rgba(255,255,255,0.05); padding: 10px 14px; border-radius: 8px;">
                        <span>Всплывающие уведомления (Toast)</span>
                        <input type="checkbox" id="tizen-sb-toast" ${window.SB_SETTINGS.showToast ? 'checked' : ''} style="width: 22px; height: 22px; accent-color: #FF0000;">
                    </label>
                    <label style="display: flex; justify-content: space-between; align-items: center; font-size: 17px; cursor: pointer; background: rgba(255,255,255,0.05); padding: 10px 14px; border-radius: 8px;">
                        <span>Пропускать спонсоров</span>
                        <input type="checkbox" id="tizen-sb-sponsor" ${window.SB_SETTINGS.skipSponsor ? 'checked' : ''} style="width: 22px; height: 22px; accent-color: #FF0000;">
                    </label>
                    <label style="display: flex; justify-content: space-between; align-items: center; font-size: 17px; cursor: pointer; background: rgba(255,255,255,0.05); padding: 10px 14px; border-radius: 8px;">
                        <span>Пропускать интро / заставки</span>
                        <input type="checkbox" id="tizen-sb-intro" ${window.SB_SETTINGS.skipIntro ? 'checked' : ''} style="width: 22px; height: 22px; accent-color: #FF0000;">
                    </label>
                </div>
                <div style="display: flex; justify-content: flex-end; margin-top: 20px;">
                    <button id="tizen-close-btn" style="background: #FF0000; color: #fff; border: none; padding: 12px 26px; font-size: 16px; font-weight: bold; border-radius: 8px; cursor: pointer;">Закрыть</button>
                </div>
            </div>
        `;

        document.body.appendChild(overlay);

        document.getElementById('tizen-sb-enabled').onchange = (e) => { window.SB_SETTINGS.enabled = e.target.checked; };
        document.getElementById('tizen-sb-toast').onchange = (e) => { window.SB_SETTINGS.showToast = e.target.checked; };
        document.getElementById('tizen-sb-sponsor').onchange = (e) => { window.SB_SETTINGS.skipSponsor = e.target.checked; };
        document.getElementById('tizen-sb-intro').onchange = (e) => { window.SB_SETTINGS.skipIntro = e.target.checked; };

        document.getElementById('tizen-close-btn').onclick = () => {
            overlay.remove();
        };
    }

    // 3. Интеграция пункта в боковое меню YouTube TV (с расширенным поиском селекторов)
    function injectMenuButton() {
        if (document.getElementById('tizen-menu-btn')) return;

        // Ищем различные варианты контейнеров меню в YouTube TV
        const navContainer = document.querySelector('ytlr-multi-page-menu-section-renderer, .menu-list, ytlr-navigation-drawer, ytlr-guide-renderer, #sections');
        if (navContainer) {
            const btn = document.createElement('div');
            btn.id = 'tizen-menu-btn';
            btn.style.cssText = `
                padding: 14px 20px;
                margin: 8px 12px;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 8px;
                color: #fff;
                font-size: 16px;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 12px;
                font-weight: 500;
                border: 1px solid rgba(255,255,255,0.05);
            `;
            btn.innerHTML = `⚙️ <span>Настройки TizenTube</span>`;
            btn.onclick = createTizenSettingsDialog;
            
            // Добавляем в начало меню
            navContainer.prepend(btn);
        }
    }

    // Проверяем появление меню каждые 1.5 секунды
    setInterval(injectMenuButton, 1500);

    // 4. Логика SponsorBlock (таймлайн и пропуск)
    let currentVideoId = null;
    let segments = [];

    const CATEGORY_COLORS = {
        sponsor: '#00D46A',
        intro: '#00C3FF',
        outro: '#00C3FF',
        interaction: '#CC00FF',
        selfpromo: '#FF9900'
    };

    const CATEGORY_NAMES = {
        sponsor: 'Спонсорская интеграция',
        intro: 'Заставка / Интро',
        outro: 'Концовка',
        interaction: 'Призыв к действию',
        selfpromo: 'Самопиар / Анонс'
    };

    function getVideoId() {
        const match = window.location.href.match(/v=([a-zA-Z0-9_-]{11})/);
        if (match) return match[1];
        const video = document.querySelector('video');
        if (video && video.src) {
            const srcMatch = video.src.match(/v=([a-zA-Z0-9_-]{11})/);
            if (srcMatch) return srcMatch[1];
        }
        return null;
    }

    function renderTimelineSegments(duration) {
        document.querySelectorAll('.sb-timeline-segment').forEach(el => el.remove());
        const progressBar = document.querySelector('.ytp-progress-bar, ytlr-progress-bar, .ytlr-progress-bar-container');
        if (!progressBar || !duration) return;

        segments.forEach(item => {
            if (!item.segment || item.segment.length !== 2) return;
            const category = item.category || 'sponsor';
            
            if (category === 'sponsor' && !window.SB_SETTINGS.skipSponsor) return;
            if (category === 'intro' && !window.SB_SETTINGS.skipIntro) return;

            const start = item.segment[0];
            const end = item.segment[1];
            const leftPercent = (start / duration) * 100;
            const widthPercent = ((end - start) / duration) * 100;

            const segmentEl = document.createElement('div');
            segmentEl.className = 'sb-timeline-segment';
            segmentEl.style.cssText = `
                position: absolute;
                left: ${leftPercent}%;
                width: ${widthPercent}%;
                height: 100%;
                background-color: ${CATEGORY_COLORS[category] || '#00D46A'};
                z-index: 10;
                pointer-events: none;
                opacity: 0.85;
                border-radius: 2px;
            `;
            progressBar.appendChild(segmentEl);
        });
    }

    function fetchSegments(videoId) {
        const categories = '["sponsor","intro","outro","interaction","selfpromo"]';
        const url = `https://sponsor.ajay.app/api/skipSegments?videoID=${videoId}&categories=${encodeURIComponent(categories)}`;

        const handleResponse = (data) => {
            try {
                segments = typeof data === 'string' ? JSON.parse(data) : data;
                const video = document.querySelector('video');
                if (video && video.duration) {
                    renderTimelineSegments(video.duration);
                }
            } catch (e) {
                segments = [];
            }
        };

        if (window.NetworkBridge && window.NetworkBridge.fetch) {
            window.NetworkBridge.fetch(url, 'GET', '', handleResponse);
        } else {
            fetch(url).then(r => r.json()).then(handleResponse).catch(() => { segments = []; });
        }
    }

    function showTizenToast(categoryName, color) {
        if (!window.SB_SETTINGS.showToast) return;
        let toast = document.getElementById('sb-tizen-toast');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'sb-tizen-toast';
            toast.style.cssText = `
                position: fixed;
                bottom: 60px;
                left: 60px;
                background: rgba(18, 18, 18, 0.94);
                border: 1px solid rgba(255, 255, 255, 0.12);
                border-left: 6px solid #00D46A;
                color: #FFFFFF;
                padding: 14px 22px;
                border-radius: 10px;
                font-family: Roboto, sans-serif;
                font-size: 20px;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 12px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.7);
                z-index: 2147483647;
                transition: opacity 0.3s ease, transform 0.3s ease;
            `;
            document.body.appendChild(toast);
        }

        toast.style.borderLeftColor = color;
        toast.innerHTML = `
            <span style="width: 10px; height: 10px; background-color: ${color}; border-radius: 50%; display: inline-block;"></span>
            <span>Пропущено: <strong>${categoryName}</strong></span>
        `;
        toast.style.opacity = '1';
        toast.style.transform = 'translateY(0)';

        clearTimeout(window.__sbToastTimeout);
        window.__sbToastTimeout = setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(10px)';
        }, 3000);
    }

    function checkAndSkip() {
        if (!window.SB_SETTINGS.enabled) return;
        const video = document.querySelector('video');
        if (!video || video.paused) return;

        const videoId = getVideoId();
        if (videoId && videoId !== currentVideoId) {
            currentVideoId = videoId;
            segments = [];
            document.querySelectorAll('.sb-timeline-segment').forEach(el => el.remove());
            fetchSegments(videoId);
        }

        if (!segments || segments.length === 0) return;
        if (video.duration && !document.querySelector('.sb-timeline-segment')) {
            renderTimelineSegments(video.duration);
        }

        const currentTime = video.currentTime;
        for (const item of segments) {
            if (item.segment && item.segment.length === 2) {
                const category = item.category || 'sponsor';
                if (category === 'sponsor' && !window.SB_SETTINGS.skipSponsor) continue;
                if (category === 'intro' && !window.SB_SETTINGS.skipIntro) continue;

                const start = item.segment[0];
                const end = item.segment.length > 1 ? item.segment[1] : 0;

                if (currentTime >= start && currentTime < end - 0.5) {
                    video.currentTime = end;
                    showTizenToast(CATEGORY_NAMES[category] || 'Интеграцию', CATEGORY_COLORS[category] || '#00D46A');
                    break;
                }
            }
        }
    }

    setInterval(checkAndSkip, 400);
})();
